# --- Postgres Configuration ---
# Used by Postgres container initialization + healthcheck
POSTGRES_DB=grit
POSTGRES_USER=grit-admin
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# --- Neo4j Configuration ---
# Used by Neo4j container auth + default database
NEO4J_DATABASE=grit
NEO4J_USER=grit-admin
NEO4J_PASSWORD=CHANGE_ME_NEO4J_PASSWORD

# --- MinIO Configuration ---
# Used by MinIO root/admin user for S3 API + Console login
MINIO_ROOT_USER=grit-admin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

# --- Redis Configuration ---
# Note: Redis container currently does NOT use a password in docker-compose.yml.
# This is reserved for scripts/tests or if you later enable Redis AUTH.
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_PORT=6379

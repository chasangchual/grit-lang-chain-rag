{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FastAPI: uv run uvicorn",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:api_service",
                "--reload",
                "--host", "0.0.0.0",
                "--port", "8000"
            ],
            "jinja": true,
            "justMyCode": true
        },
        {
            "name": "Embedding: run_embedding.py",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/run_embedding.py",
            "args": [],
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
